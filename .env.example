# ============================================================================
# Golden Config — environment configuration
# Copy to `.env` and adjust. NEVER commit a real `.env`.
# ============================================================================

# ---- General ----
ENVIRONMENT=development
LOG_LEVEL=INFO
PROJECT_NAME=Golden Config

# ---- Backend / API ----
API_V1_PREFIX=/api/v1
BACKEND_CORS_ORIGINS=http://localhost:5173,http://localhost:3000

# ---- Security / JWT ----
# Generate with: python -c "import secrets; print(secrets.token_urlsafe(48))"
SECRET_KEY=change-me-in-production-please-use-a-long-random-string
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7
# Fernet key for encrypting stored device credentials at rest.
# Generate with: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
CREDENTIAL_ENCRYPTION_KEY=change-me-32-url-safe-base64-bytes-aaaaaaaaaa=

# ---- Database (PostgreSQL) ----
POSTGRES_USER=goldenconfig
POSTGRES_PASSWORD=goldenconfig
POSTGRES_DB=goldenconfig
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
# Optional explicit URL (overrides the parts above if set)
# DATABASE_URL=postgresql+asyncpg://goldenconfig:goldenconfig@postgres:5432/goldenconfig

# ---- Redis / Celery ----
REDIS_HOST=redis
REDIS_PORT=6379
CELERY_BROKER_URL=redis://redis:6379/0
CELERY_RESULT_BACKEND=redis://redis:6379/1
CACHE_REDIS_URL=redis://redis:6379/2

# ---- Bootstrap admin (created on first startup) ----
FIRST_ADMIN_USERNAME=admin
FIRST_ADMIN_EMAIL=admin@goldenconfig.local
FIRST_ADMIN_PASSWORD=admin12345

# ---- Observability ----
OTEL_ENABLED=false
OTEL_EXPORTER_OTLP_ENDPOINT=http://otel-collector:4317
OTEL_SERVICE_NAME=golden-config-api

# ---- Frontend (build-time) ----
VITE_API_BASE_URL=http://localhost:8000/api/v1
