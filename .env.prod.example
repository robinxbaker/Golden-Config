# ===== Golden Config — production environment =====
# Copy to .env on the server, then fill in REAL values before deploying:
#   cp .env.prod.example .env && nano .env
# Never commit the real .env.

# ---- Public URL / TLS ----
DOMAIN=demo.yourdomain.com
ACME_EMAIL=you@example.com

# ---- App ----
ENVIRONMENT=production
LOG_LEVEL=INFO
# Same-origin means CORS is not strictly required, but keep it locked to your domain.
BACKEND_CORS_ORIGINS=https://demo.yourdomain.com

# ---- Security (GENERATE NEW VALUES — do NOT ship these placeholders) ----
# SECRET_KEY:                 python3 -c "import secrets;print(secrets.token_urlsafe(48))"
# CREDENTIAL_ENCRYPTION_KEY:  python3 -c "from cryptography.fernet import Fernet;print(Fernet.generate_key().decode())"
SECRET_KEY=CHANGE_ME
CREDENTIAL_ENCRYPTION_KEY=CHANGE_ME
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# ---- Database ----
POSTGRES_USER=goldenconfig
POSTGRES_PASSWORD=CHANGE_ME_strong_password
POSTGRES_DB=goldenconfig
POSTGRES_HOST=postgres
POSTGRES_PORT=5432

# ---- Redis / Celery (service names from docker-compose.prod.yml) ----
REDIS_HOST=redis
REDIS_PORT=6379
CELERY_BROKER_URL=redis://redis:6379/0
CELERY_RESULT_BACKEND=redis://redis:6379/1
CACHE_REDIS_URL=redis://redis:6379/2
CACHE_TTL_SECONDS=60

# ---- Bootstrap admin (the login you give the interviewer) ----
FIRST_ADMIN_USERNAME=admin
FIRST_ADMIN_EMAIL=admin@goldenconfig.local
FIRST_ADMIN_PASSWORD=CHANGE_ME_demo_password
